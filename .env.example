# Copy to .env and fill in. Never commit the real .env.

# Anthropic — powers the Mastra agents
ANTHROPIC_API_KEY=sk-ant-...

# Browserbase — cloud browsers the agents drive
BROWSERBASE_API_KEY=bb-...
BROWSERBASE_PROJECT_ID=...

# Optional overrides
# CONCIERGE_MODEL=anthropic/claude-opus-4-8
# APPLY_URL=https://<your-portal>/Resident/rental-application/new
# APPLY_PROPERTY=424242 Fell St - 42
# APPLY_PRICE=$2,850
